{
  "manifest_version": 3,
  "name": "FU-1 Drafter",
  "version": "1.0",
  "description": "Drafts follow-up emails in Gmail by extracting the recipient's name from the original email.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://mail.google.com/*"
  ],
  "action": {
    "default_title": "Draft Follow-Up",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}